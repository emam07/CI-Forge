# --- Database ---
DATABASE_URL="postgresql://ciforge:ciforge@localhost:5432/ciforge?schema=public"

# --- GitHub App ---
# Created at https://github.com/settings/apps/new
# Permissions: Actions:read, Contents:read, Pull requests:write, Metadata:read
# Webhook events: pull_request, workflow_run, workflow_job, check_suite, installation
GITHUB_APP_ID=""
GITHUB_APP_CLIENT_ID=""
GITHUB_APP_CLIENT_SECRET=""
# Paste the *contents* of the .pem file. Newlines preserved (use $'...' or quoted).
GITHUB_APP_PRIVATE_KEY=""
# The webhook secret you set when creating the App.
GITHUB_APP_WEBHOOK_SECRET=""

# --- Public URL (for webhook delivery in dev, use smee.io or ngrok) ---
PUBLIC_BASE_URL="http://localhost:3000"
